# Public frontend URL. Use your domain in production.
APP_URL="http://localhost:3000"

# GraphQL backend URL used by the browser.
# Keep "/graphql" for production/IP/domain access; the frontend server and Nginx proxy it to the backend.
# Use "http://localhost:4000/graphql" for local direct backend access.
VITE_GRAPHQL_URL="/graphql"

# Backend payment callback base (set in x/.env for local API server).
API_BASE_URL="http://localhost:4000"
# Optional self-hosted coturn relay for reliable Social audio/video calls and
# live co-hosting across carrier NAT. Keep SOCIAL_TURN_SECRET only in the
# server environment; it must match coturn's static-auth-secret.
# SOCIAL_TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
# SOCIAL_TURN_SECRET=replace-with-a-long-random-server-secret
