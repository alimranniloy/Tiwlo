DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tiwlo?schema=public"
JWT_SECRET="change-this-before-production"
PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"
API_BASE_URL="http://localhost:4000"
AUTOMATION_API_TOKEN="change-this-automation-token"

# Tiwi Social media, WebRTC and live-streaming infrastructure.
SOCIAL_MEDIA_MAX_MB=500
SOCIAL_FFMPEG_PATH="ffmpeg"
# Optional audio-rights matching. Install Chromaprint's fpcalc on the server and
# configure only tracks for which Tiwi has a rights policy. Do not use public
# metadata lookup results as a rights decision.
SOCIAL_CHROMAPRINT_PATH="fpcalc"
SOCIAL_AUDIO_RIGHTS_CATALOG_JSON='[]'
# Optional licensed acoustic-recognition webhook. It receives a decoded-audio
# fingerprint and may return {referenceId, ownerId, confidence, policy} for
# robust cut/overlay/background-audio matching. Do not point this at a public
# metadata-only music lookup.
SOCIAL_AUDIO_FINGERPRINT_WEBHOOK_URL=""
SOCIAL_AUDIO_FINGERPRINT_WEBHOOK_TOKEN=""
SOCIAL_RTMP_URL="rtmp://localhost:1935/live"
SOCIAL_LIVE_PLAYBACK_URL="/live"

# Local system mail relay. Public clients still use mail.example.com, while the backend
# sends through the same server over loopback to avoid public DNS/firewall hairpin issues.
SMTP_HOST="127.0.0.1"
SMTP_PUBLIC_HOST="mail.example.com"
SMTP_TLS_SERVERNAME="mail.example.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_FORCE_IPV4="true"
SMTP_TLS_REJECT_UNAUTHORIZED="false"
SMTP_USER="noreply"
SMTP_PASS=""
MAIL_FROM="noreply@example.com"
MAIL_FROM_NAME="Tiwlo"
MAIL_REPLY_TO="noreply@example.com"
MAIL_DISABLE_IPV6="true"
MAIL_IPV4=""
MAIL_IPV6=""
TIWLO_DKIM_SELECTOR="tiwlo"
TIWLO_DKIM_PUBLIC_KEY=""
TIWLO_BIMI_LOGO_URL=""
TIWLO_BIMI_CERT_URL=""

# Optional: comma-separated browser origins that may call the GraphQL API directly.
# Same-host IP/domain requests are allowed automatically, and /graphql proxy avoids CORS in production.
CORS_ORIGINS=""
CORS_ALLOW_ALL="false"

# Stripe Checkout
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PayPal Orders v2
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# bKash Tokenized Checkout
BKASH_APP_KEY=""
BKASH_APP_SECRET=""
BKASH_USERNAME=""
BKASH_PASSWORD=""
BKASH_BASE_URL="https://tokenized.pay.bka.sh/v1.2.0-beta/tokenized"
PAYMENT_RATE_USD_BDT="110"
