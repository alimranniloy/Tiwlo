{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:all": "powershell -ExecutionPolicy Bypass -File ./scripts/start-tiwlo.ps1",
    "start:all": "powershell -ExecutionPolicy Bypass -File ./scripts/start-tiwlo.ps1",
    "backend": "npm --prefix x run dev",
    "backend:db:push": "npm --prefix x run db:push",
    "backend:db:seed": "npm --prefix x run db:seed",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "node scripts/serve-tiwlo-frontend.mjs",
    "start": "node scripts/serve-tiwlo-frontend.mjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": "24.15.0",
    "npm": ">=10"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "compression": "^1.8.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "libphonenumber-js": "^1.13.4",
    "lucide-react": "^0.546.0",
    "material-icons": "^1.13.14",
    "motion": "^12.38.0",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
